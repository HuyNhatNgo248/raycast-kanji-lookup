{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "version": "1.0.0",
  "name": "kanji-lookup",
  "title": "Kanji Lookup",
  "description": "Translate kanji to English and get hiragana readings",
  "icon": "extension-icon.png",
  "author": "your-raycast-username",
  "categories": [
    "Productivity",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "lookup-kanji",
      "title": "Lookup Kanji",
      "subtitle": "Get English translation and hiragana reading",
      "description": "Paste kanji to get English translation and hiragana reading",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.70.0",
    "@raycast/utils": "^1.15.0",
    "ts-markdown-builder": "^0.6.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "18.2.27",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish",
    "build:kanji": "ts-node src/scripts/build-index.ts"
  }
}
